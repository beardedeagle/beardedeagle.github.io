<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {{ site.name }}{% else %}{{ site.name }} · {{ site.title }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">

  <!-- Fonts: IBM Plex family -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/main.css">

  {% block head %}{% endblock %}
</head>
<body>
  <nav class="site-nav">
    <div class="site-nav__inner">
      <a href="/" class="site-nav__brand">
        <span class="site-nav__sigil">&gt;_</span>
        <span class="site-nav__name">{{ site.handle }}</span>
      </a>
      <div class="site-nav__links">
        <a href="/" class="site-nav__link{% if page.url == '/' %} site-nav__link--active{% endif %}">Home</a>
        <a href="/projects/" class="site-nav__link{% if '/projects' in page.url %} site-nav__link--active{% endif %}">Projects</a>
        <a href="{{ site.resume }}" class="site-nav__link site-nav__link--ext" target="_blank" rel="noopener">Resume</a>
        <a href="{{ site.github }}" class="site-nav__link site-nav__link--ext" target="_blank" rel="noopener">GitHub</a>
        <a href="{{ site.linkedin }}" class="site-nav__link site-nav__link--ext" target="_blank" rel="noopener">LinkedIn</a>
      </div>
    </div>
  </nav>

  <main class="site-main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="site-footer__inner">
      <p>&copy; {{ site.name }} · Built with care, not frameworks.</p>
    </div>
  </footer>

  {% block scripts %}{% endblock %}
</body>
</html>
