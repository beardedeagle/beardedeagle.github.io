---
layout: layouts/base.njk
---

<article class="project-detail">
  <header class="project-detail__header">
    <div class="project-detail__meta">
      {% status status %}
      <div class="project-detail__stack">
        {% for t in stack %}<span class="tech-tag">{{ t }}</span>{% endfor %}
      </div>
    </div>
    <h1 class="project-detail__title">{{ title }}</h1>
    <p class="project-detail__tagline">{{ tagline }}</p>
    {% if repo %}
    <a href="{{ repo }}" class="project-detail__repo" target="_blank" rel="noopener">View Source →</a>
    {% endif %}
  </header>

  <div class="project-detail__body prose">
    {{ content | safe }}
  </div>

  <nav class="project-detail__nav">
    <a href="/projects/">← All Projects</a>
  </nav>
</article>

{% block scripts %}
<script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
<script>
  mermaid.initialize({
    startOnLoad: true,
    theme: 'dark',
    themeVariables: {
      darkMode: true,
      background: '#131b2e',
      primaryColor: '#1e3a5f',
      primaryTextColor: '#e2e8f0',
      primaryBorderColor: '#22d3ee',
      lineColor: '#475569',
      secondaryColor: '#1a2332',
      tertiaryColor: '#0f172a'
    }
  });
</script>
{% endblock %}
